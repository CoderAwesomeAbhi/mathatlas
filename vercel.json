{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "problems.js", "use": "@vercel/static" },
    { "src": "problems-base.json", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/problems.js", "dest": "/problems.js" },
    { "src": "/problems-base.json", "dest": "/problems-base.json" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
